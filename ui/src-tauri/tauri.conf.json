{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SyncDrive",
  "version": "0.1.0",
  "identifier": "com.syncdrive.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SyncDrive",
        "width": 980,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8737; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "appimage"],
    "externalBin": ["binaries/syncdrived"],
    "icon": []
  }
}
