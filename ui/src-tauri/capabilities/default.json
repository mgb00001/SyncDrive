{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "SyncDrive main window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/syncdrived", "sidecar": true, "args": true }]
    }
  ]
}
